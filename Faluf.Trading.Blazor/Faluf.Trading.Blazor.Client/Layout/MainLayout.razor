@using Faluf.Trading.Blazor.Client.Pages
@inherits LayoutComponentBase

<div class="page">
	<div class="sidebar">
		<NavMenu />
	</div>

	<main>
		<div class="top-row px-4 gap-4">
			<CultureSelector />

			<AuthorizeView>
				<Authorized>
					<p>Hello, @context.User.Identity?.Name!</p>
				</Authorized>

				<NotAuthorized>
					<p>Not authorized</p>
				</NotAuthorized>
			</AuthorizeView>
		</div>

		<article class="content px-4">
			@Body

			<article class="bottom-row px-4">
			</article>
		</article>
	</main>
</div>

<div id="blazor-error-ui">
	An unhandled error has occurred.
	<a href="" class="reload">Reload</a>
	<a class="dismiss">🗙</a>
</div>